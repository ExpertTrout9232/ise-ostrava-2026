# SFTP deployment configuration
# Copy this file to .env and fill in all values.
# Never commit .env - it is already in .gitignore.

# Server hostname or IP address.
SFTP_HOST=server.domain.cz

# SFTP port (usually 22). Optional, defaults to 22.
# SFTP_PORT=22

# Username for SFTP authentication.
SFTP_USER=your_username

# Password for SFTP authentication.
SFTP_PASSWORD=your_password

# Remote directory path where index.html will reside.
# The entire contents of src/ will be uploaded here.
# Example: /var/www/html/ise-2026
SFTP_REMOTE_PATH=/var/www/html/ise-ostrava-2026
